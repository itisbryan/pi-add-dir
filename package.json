{
  "name": "pi-add-dir",
  "version": "1.1.0",
  "description": "Add external directories to your pi session — loads their AGENTS.md, CLAUDE.md, and skills into context.",
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "external-directory",
    "multi-project",
    "context"
  ],
  "scripts": {
    "lint": "eslint . && tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test"
  },
  "author": "itisbryan",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/itisbryan/pi-add-dir.git"
  },
  "homepage": "https://github.com/itisbryan/pi-add-dir#readme",
  "bugs": {
    "url": "https://github.com/itisbryan/pi-add-dir/issues"
  },
  "files": [
    "extensions",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "image": "https://raw.githubusercontent.com/itisbryan/pi-add-dir/main/demo.svg"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@mariozechner/pi-tui": "^0.64.0",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
